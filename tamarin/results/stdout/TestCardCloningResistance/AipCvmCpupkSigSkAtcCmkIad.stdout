                        AC.127, IAD.133>), 
                     UN.137>,
                    x.240)
       UN    = UN.137
       nc    = nc.138
       pubkCA
             = pk(x.242)
       pubkCard
             = pk(x.240)
       pubkCardSigned
             = sign(pk(x.240), x.242)
       z     = true
       z.1   = true
  */

rule (modulo E) Bank_Accepts_Online_AC:
   [
   !SKB( Token, SessionKey ),
   Recv( $Terminal, $Bank, channelID,
         <Token, AC, CID, AIP, CDOL1, ATC, IAD, POS_Cardholder_Info, Token, AIP, 
          CVM, CDOL1, PDOL, ATC, AC, IAD>
   )
   ]
  --[
  Once( <$Bank, channelID, Token, AIP, CVM, CDOL1, PDOL, ATC, AC, IAD> ),
  Eq( AC, MAC(SessionKey, <AIP, CID, CDOL1, IAD, ATC>) ),
  Bank_Accepts( <Token, AIP, CVM, CDOL1, PDOL, ATC, AC, IAD> )
  ]->
   [
   Send( $Bank, $Terminal, channelID,
         <<Token, AIP, CVM, CDOL1, PDOL, ATC, AC, IAD>, 'YES'>
   )
   ]

  /* has exactly the trivial AC variant */

