restriction equal:
  "∀ a b #i. (Eq( a, b ) @ #i) ⇒ (a = b)"
  // safety formula

restriction not_equal:
  "∀ a #i. (NEq( a, a ) @ #i) ⇒ (⊥)"
  // safety formula

restriction once:
  "∀ a #i #j. ((Once( a ) @ #i) ∧ (Once( a ) @ #j)) ⇒ (#i = #j)"
  // safety formula

lemma TestSimultaneousAuthentication:
  all-traces
  "∀ tx #i.
    (Terminal_Accepts_Tx( tx ) @ #i) ⇒ (¬(∃ #j. Bank_Declines( tx ) @ #j))"
/*
guarded formula characterizing all counter-examples:
"∃ tx #i.
  (Terminal_Accepts_Tx( tx ) @ #i) ∧ ∃ #j. (Bank_Declines( tx ) @ #j)"
*/
by sorry

lemma TestCardCloningResistance:
  all-traces "¬(∃ tx #i. Terminal_Accepts_Tx( tx ) @ #i)"
/*
guarded formula characterizing all counter-examples:
"∃ tx #i. (Terminal_Accepts_Tx( tx ) @ #i)"
*/
simplify
solve( Terminal_Accepts_Tx( tx ) @ #i )
  case Terminal_Accepts_Offline_AC
  solve( Terminal_Sent_GenerateAC_CDA( $Terminal,
                                       <'TVR', CVM, 'CDA', 'HHMMSS', $Amount>, <UN, AIP, AC_Type>
         ) ▶₀ #i )
    case Terminal_Sends_Offline_GenerateAC
    solve( !Pk( Token, pk(x) ) ▶₂ #i )
      case Adversarial_Wallet_Ready
      solve( !PublicKeySignedByCA( sign(pk(x), x.1) ) ▶₃ #i )
        case CA_init
        solve( !PubKeyCA( $CA, pk(~privkCA) ) ▶₄ #i )
          case CA_init
          solve( !KU( sign(<nc, 'TC', AC, 
                            h(<<'TVR', CVM, 'CDA', 'HHMMSS', $Amount>, ATC, 'TC', AC, IAD>), ~UN>,
                           ~privCard)
                 ) @ #vk.38 )
            case Card_Produces_Offline_AC
            by solve( !KU( ~privCard ) @ #vk.53 )
          next
            case c_sign
            by solve( !KU( ~privCard ) @ #vk.60 )
          qed
        qed
      qed
    qed
  qed
next
  case Terminal_Accepts_Online_Transaction
  solve( Recv( $Bank, $Terminal, channelID,
               <<Token, AIP, CVM, CDOL1, PDOL, ATC, AC, IAD>, 'YES'>
         ) ▶₀ #i )
    case Terminal_Bank_Network
    solve( Send( $Bank, $Terminal, channelID,
                 <<Token, AIP, CVM, CDOL1, PDOL, ATC, AC, IAD>, 'YES'>
           ) ▶₀ #vr )
      case Bank_Accepts_Online_AC
      solve( Send( $Terminal, $Bank, channelID,
                   <~Token, MAC(f(~CMK, ~ATC.1), <AIP, CID, CDOL1, IAD, ATC>), CID, AIP, 
                    CDOL1, ATC, IAD, POS_Cardholder_Info, ~Token, AIP, CVM, CDOL1, PDOL, 
                    ATC, MAC(f(~CMK, ~ATC.1), <AIP, CID, CDOL1, IAD, ATC>), IAD>
             ) ▶₀ #vr.3 )
        case Terminal_Receives_Online_AC
        by solve( !KU( ~Token ) @ #vk.7 )
      qed
    qed
  qed
qed

























